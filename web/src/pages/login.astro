---
import Base from '../layouts/Base.astro';

// Passwordless sign-in. The form posts (no JS required) to /api/auth/magic-link,
// which emails a one-time link; clicking it lands on /auth/callback and the
// session is set.
//
// ?next=… is where to land after sign-in (e.g. /checkout, from the checkout
// gate). Local paths only — never an off-site redirect. Already-signed-in
// visitors skip straight there (or to /account).
const nextRaw = Astro.url.searchParams.get('next') ?? '';
const next = /^\/(?!\/)/.test(nextRaw) ? nextRaw : '';
if (Astro.locals.user) return Astro.redirect(next || '/account');

// ?sent=1 → we just emailed a link. ?error=… → something went wrong. The email
// is echoed back purely to reassure ("we sent it there"), never trusted.
const sent = Astro.url.searchParams.get('sent') === '1';
const sentTo = Astro.url.searchParams.get('to') ?? '';
const error = Astro.url.searchParams.get('error');
const resendHref = next ? `/login?next=${encodeURIComponent(next)}` : '/login';
const forCheckout = next === '/checkout';
---

<Base title="Sign in — DOKU">
  <div class="narrow">
    <div class="page-head">
      <div class="eyebrow">Your account</div>
      <h1 class="serif">Sign in</h1>
      <p>{forCheckout
        ? 'One step before you claim. We send a link; it signs you in — no password. Your held pieces stay held.'
        : 'No passwords. We send a link; it signs you in.'}</p>
    </div>

    {sent ? (
      <div class="story-block">
        <p>Check your inbox{sentTo ? <> at <strong>{sentTo}</strong></> : null}. The link signs you in — it works once, and only on this device{forCheckout ? <>, then brings you back to check out</> : null}.</p>
        <p class="fine-print">Didn't arrive? <a href={resendHref}>Send another</a>. Give it a minute; check spam.</p>
      </div>
    ) : (
      <form method="POST" action="/api/auth/magic-link" novalidate>
        {next && <input type="hidden" name="next" value={next} />}
        {error && (
          <div class="claim-sub" style="color:var(--gold); margin-bottom:18px;">
            That didn't work. Try requesting a fresh link.
          </div>
        )}
        <fieldset>
          <legend>Email</legend>
          <div class="form-group">
            <label for="email">Where should the link go?</label>
            <input id="email" type="email" name="email" required autocomplete="email" inputmode="email" />
          </div>
          <p class="fine-print">
            We store only your email and — if you save one — a shipping address.
            Nothing else. See <a href="/privacy">Privacy</a>.
          </p>
        </fieldset>
        <button class="btn-gold" type="submit" style="margin-top:28px;"><span>Send the link</span></button>
      </form>
    )}
  </div>
</Base>
