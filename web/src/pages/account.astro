---
import Base from '../layouts/Base.astro';

// Protected. The point of an account is a few RLS-scoped reads, all pinned to
// the signed-in user: their past orders (matched on verified JWT email), their
// one saved shipping address (auth.uid()), and their wishlist (auth.uid()).
// Guests never reach here — bounce to sign-in.
const { user, supabase } = Astro.locals;
if (!user) return Astro.redirect('/login');

const saved = Astro.url.searchParams.get('saved') === '1';
const addrError = Astro.url.searchParams.get('error') === 'address';
const deleteError = Astro.url.searchParams.get('error') === 'delete';

// Saved address (own row only — RLS). maybeSingle: no row yet is fine.
const { data: address } = await supabase
  .from('customer_addresses')
  .select('full_name, address, city, postcode, country')
  .maybeSingle();

// Wishlist: own rows only (RLS), newest first, joined to the live product so we
// can show each item's current status. A wishlist never reserves anything — the
// piece may have been claimed by someone else since it was saved.
const { data: watchRows } = await supabase
  .from('wishlists')
  .select('sku, created_at, products(title, status)')
  .order('created_at', { ascending: false });
interface Watch { sku: string; title: string; status: string; }
const watching: Watch[] = (watchRows ?? []).map((r: any) => ({
  sku: r.sku,
  title: r.products?.title ?? r.sku,
  status: r.products?.status ?? 'available',
}));
const STATUS_WORD: Record<string, string> = {
  available: 'Available', 'coming-soon': 'Coming soon', reserved: 'Held', claimed: 'Claimed',
};

// Orders: one row per item, grouped here under their shared order_code. RLS
// returns only rows whose email matches this user's verified email — including
// anything they bought as a guest with the same address. `amount_inr` is the
// real Razorpay charge in paise (same on every row of an order), so that — not
// the per-row USD `price` mislabelled 'INR' — is the honest total. order_status
// / tracking_note are also shared across an order's rows.
const { data: rows } = await supabase
  .from('orders')
  .select('order_code, title, amount_inr, created_at, order_status, tracking_note')
  .order('created_at', { ascending: false });

interface Order { code: string; date: string; items: string[]; amountInr: number | null; status: string; trackingNote: string | null; }
const orders: Order[] = [];
const byCode = new Map<string, Order>();
for (const r of rows ?? []) {
  let o = byCode.get(r.order_code);
  if (!o) {
    o = { code: r.order_code, date: r.created_at, items: [], amountInr: r.amount_inr ?? null, status: r.order_status ?? 'reserved', trackingNote: r.tracking_note ?? null };
    byCode.set(r.order_code, o);
    orders.push(o);
  }
  o.items.push(r.title);
}

const STAGES = ['reserved', 'confirmed', 'shipped', 'delivered'] as const;
const STAGE_LABEL: Record<string, string> = { reserved: 'Reserved', confirmed: 'Confirmed', shipped: 'Shipped', delivered: 'Delivered' };
const stageIndex = (s: string) => { const i = (STAGES as readonly string[]).indexOf(s); return i < 0 ? 0 : i; };

const inr = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 });
const money = (paise: number | null) => (paise == null ? '—' : inr.format(paise / 100));
const day = (iso: string) => new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---

<Base title="Your account — DOKU">
  <div class="narrow">
    <div class="page-head">
      <div class="eyebrow">{user.email}</div>
      <h1 class="serif">Your account</h1>
      <p>What you're watching, what you've claimed, and where it ships.</p>
    </div>

    <section class="account-block">
      <div class="section-kicker">Where it ships</div>
      <h2 class="serif account-h2">Shipping address</h2>
      <p class="section-note">Saved once, offered back to you at checkout. Yours alone.</p>
      {saved && <div class="status-note">Saved.</div>}
      {addrError && <div class="status-note">Every field's needed — nothing saved.</div>}
      <form method="POST" action="/api/account/address" novalidate>
        <div class="form-group"><label for="fullName">Full name</label><input id="fullName" name="fullName" required autocomplete="name" value={address?.full_name ?? ''} /></div>
        <div class="form-group"><label for="address">Address</label><input id="address" name="address" required autocomplete="street-address" value={address?.address ?? ''} /></div>
        <div class="form-row">
          <div class="form-group"><label for="city">City</label><input id="city" name="city" required autocomplete="address-level2" value={address?.city ?? ''} /></div>
          <div class="form-group"><label for="postcode">Postcode</label><input id="postcode" name="postcode" required autocomplete="postal-code" value={address?.postcode ?? ''} /></div>
        </div>
        <div class="form-group"><label for="country">Country</label><input id="country" name="country" required autocomplete="country-name" value={address?.country ?? ''} /></div>
        <button class="btn-ghost" type="submit" style="margin-top:8px;">{address ? 'Update address' : 'Save address'}</button>
      </form>
    </section>

    <section class="account-block">
      <div class="section-kicker">Your list</div>
      <h2 class="serif account-h2">Watching</h2>
      <p class="section-note">A list, not a hold. Watching a piece doesn't take it off the market.</p>
      {watching.length === 0 ? (
        <p class="empty-note">Nothing yet. On any piece, <em>Keep an eye on this</em> saves it here.</p>
      ) : (
        <div class="watch-list">
          {watching.map((w) => (
            <div class="watch-row">
              <div class="watch-main">
                <a class="watch-title serif" href={`/item/${w.sku}`}>{w.title}</a>
                <span class:list={['watch-status', { gone: w.status === 'claimed' || w.status === 'reserved' }]}>{STATUS_WORD[w.status] ?? w.status}</span>
              </div>
              <form method="POST" action="/api/account/wishlist">
                <input type="hidden" name="action" value="remove" />
                <input type="hidden" name="sku" value={w.sku} />
                <input type="hidden" name="redirect" value="/account" />
                <button class="btn-text" type="submit">Remove</button>
              </form>
            </div>
          ))}
        </div>
      )}
    </section>

    <section class="account-block">
      <div class="section-kicker">Orders</div>
      <h2 class="serif account-h2">Order history</h2>
      {orders.length === 0 ? (
        <p class="empty-note">Nothing yet. <a href="/collection">The collection</a> is where it starts.</p>
      ) : (
        <div class="order-list">
          {orders.map((o) => (
            <div class="order-row">
              <div class="order-meta">
                <span class="order-code serif">{o.code}</span>
                <span class="order-date">{day(o.date)}</span>
              </div>
              <div class="order-items">{o.items.join(' · ')}</div>
              <div class="order-amount serif">{money(o.amountInr)}</div>
              <ol class="stepper" aria-label="Order status">
                {STAGES.map((s, i) => (
                  <li class:list={['step', { done: i <= stageIndex(o.status), current: i === stageIndex(o.status) }]}>
                    <span class="dot"></span>
                    <span class="step-label">{STAGE_LABEL[s]}</span>
                  </li>
                ))}
              </ol>
              {(o.status === 'shipped' || o.status === 'delivered') && o.trackingNote && (
                <div class="tracking-note">{o.trackingNote}</div>
              )}
            </div>
          ))}
        </div>
      )}
      {orders.length > 0 && (
        <p class="section-note" style="margin:22px 0 0;">Amounts show what Razorpay charged, in INR. A reserved piece becomes yours once we've confirmed and shipped it.</p>
      )}
    </section>

    <section class="account-block">
      <details class="danger-zone">
        <summary>Close account</summary>
        {deleteError && <div class="status-note" style="margin-top:14px;">Something went wrong — nothing was deleted. Try again.</div>}
        <p class="section-note" style="margin-top:14px;">
          This removes your sign-in and your saved address for good. Your order
          records stay with us as receipts — they're how we honour what you've
          bought. This can't be undone.
        </p>
        <form method="POST" action="/api/account/delete">
          <label class="confirm-line">
            <input type="checkbox" name="confirm" value="delete" required />
            <span>I understand my account and saved address will be permanently deleted.</span>
          </label>
          <button class="btn-danger" type="submit">Delete my account</button>
        </form>
      </details>
    </section>

    <section class="account-block">
      <form method="POST" action="/api/auth/signout">
        <button class="btn-text" type="submit">Sign out</button>
      </form>
    </section>
  </div>
</Base>

<style>
  /* Deliberate whitespace + thin Fraunces heads, matching the rest of the site
     (Presence + Restraint). Section pattern: gold kicker → serif statement. */
  .account-block { padding: 46px 0; border-top: 1px solid var(--hairline); }
  .account-block:first-of-type { border-top: none; padding-top: 4px; }
  .section-kicker {
    font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 14px;
  }
  .account-h2 {
    font-family: 'Fraunces', serif; font-weight: 300; font-size: 28px;
    line-height: 1.08; color: var(--ivory); margin: 0 0 8px;
  }
  .section-note { font-size: 12px; color: var(--claimed); line-height: 1.75; margin: 0 0 26px; max-width: 56ch; }
  .section-note em { font-style: italic; color: var(--muted); }
  .status-note { font-size: 12px; color: var(--gold); margin: 0 0 22px; }
  .empty-note { font-size: 14px; color: var(--claimed); line-height: 1.7; margin: 2px 0 0; }
  .empty-note a { color: var(--gold); }
  .empty-note em { font-style: italic; color: var(--muted); }

  /* Watching */
  .watch-list { display: flex; flex-direction: column; }
  .watch-row {
    display: flex; justify-content: space-between; align-items: baseline; gap: 16px;
    padding: 17px 0; border-bottom: 1px solid var(--hairline);
  }
  .watch-row:first-child { padding-top: 0; }
  .watch-row:last-child { border-bottom: none; }
  .watch-main { display: flex; gap: 14px; align-items: baseline; flex-wrap: wrap; }
  .watch-title {
    font-family: 'Fraunces', serif; font-weight: 400; font-size: 18px;
    color: var(--ivory); text-decoration: none; transition: color .3s var(--ease);
  }
  .watch-title:hover { color: var(--gold); }
  .watch-status { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); }
  .watch-status.gone { color: var(--claimed); }

  /* Order history */
  .order-list { display: flex; flex-direction: column; }
  .order-row {
    display: grid; grid-template-columns: 1fr auto; gap: 6px 16px;
    align-items: baseline; padding: 24px 0; border-bottom: 1px solid var(--hairline);
  }
  .order-row:first-child { padding-top: 2px; }
  .order-row:last-child { border-bottom: none; }
  .order-meta { display: flex; gap: 12px; align-items: baseline; }
  .order-code { font-family: 'Fraunces', serif; color: var(--ivory); font-size: 16px; letter-spacing: .02em; }
  .order-date { color: var(--claimed); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; }
  .order-items { grid-column: 1; color: var(--muted); font-size: 13px; line-height: 1.6; }
  .order-amount {
    grid-column: 2; grid-row: 1 / span 2; font-family: 'Fraunces', serif; font-size: 17px;
    color: var(--gold); align-self: center; white-space: nowrap;
  }

  /* Fulfillment stepper */
  .stepper { grid-column: 1 / -1; list-style: none; display: flex; margin: 20px 0 0; padding: 0; }
  .step { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 9px; position: relative; }
  .step + .step::before {
    content: ''; position: absolute; top: 4px; left: -50%; width: 100%; height: 1px; background: var(--hairline);
  }
  .step.done + .step.done::before, .step.done.current::before { background: var(--gold); }
  .step .dot {
    width: 9px; height: 9px; border-radius: 50%; background: var(--bg-card);
    border: 1px solid var(--hairline); position: relative; z-index: 1; transition: background .4s var(--ease);
  }
  .step.done .dot { background: var(--gold); border-color: var(--gold); }
  .step.current .dot { box-shadow: 0 0 0 3px var(--gold-soft); }
  .step-label { font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--claimed); }
  .step.done .step-label { color: var(--ivory); }
  .step.current .step-label { color: var(--gold); }
  .tracking-note { grid-column: 1 / -1; margin-top: 12px; font-size: 13px; color: var(--muted); line-height: 1.6; }

  /* Close account — quiet by default, deliberate to open */
  .danger-zone summary {
    cursor: pointer; color: var(--claimed); font-size: 10px; letter-spacing: 0.18em;
    text-transform: uppercase; list-style: none; display: inline-flex; align-items: center;
    gap: 9px; transition: color .3s var(--ease);
  }
  .danger-zone summary::-webkit-details-marker { display: none; }
  .danger-zone summary::before { content: '+'; color: var(--gold); font-size: 13px; line-height: 1; }
  .danger-zone[open] summary::before { content: '\2013'; }
  .danger-zone summary:hover { color: var(--ivory); }
  .confirm-line {
    display: flex; gap: 11px; align-items: flex-start; margin: 20px 0;
    font-size: 13px; color: var(--muted); line-height: 1.6; max-width: 56ch;
  }
  .confirm-line input { margin-top: 2px; accent-color: var(--gold); flex-shrink: 0; }
  .btn-danger {
    background: none; border: 1px solid var(--hairline); color: var(--claimed); font: inherit;
    font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; padding: 13px 24px;
    cursor: pointer; transition: border-color .3s var(--ease), color .3s var(--ease);
  }
  .btn-danger:hover { border-color: var(--claimed); color: var(--ivory); }

  /* Text buttons (Remove, Sign out) — match the site's .cart-row .remove idiom */
  .btn-text {
    background: none; border: none; color: var(--claimed); cursor: pointer; font: inherit;
    font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; padding: 0;
    border-bottom: 1px solid transparent; transition: color .3s var(--ease), border-color .3s var(--ease);
  }
  .btn-text:hover { color: var(--ivory); border-bottom-color: var(--ivory); }
</style>
