---
import Base from '../layouts/Base.astro';
import ItemCard from '../components/ItemCard.astro';
import ArchiveCard from '../components/ArchiveCard.astro';
import { fetchProducts } from '../lib/products';
import { fetchRates, currencyFromCookieValue, CURRENCY_COOKIE } from '../lib/currency';
import { CART_COOKIE, decodeCart } from '../lib/cart';
import { serverEnv } from '../lib/env';

// SSR pulls the live catalog from Supabase (falling back to FALLBACK_PRODUCTS
// on failure) before the HTML is sent.
const products = await fetchProducts();
const available = products.filter((p) => p.status === 'available');
const comingSoon = products.filter((p) => p.status === 'coming-soon');
const claimed = products.filter((p) => p.status === 'claimed');

const currency = currencyFromCookieValue(Astro.cookies.get(CURRENCY_COOKIE)?.value);
const rates = await fetchRates();

const cartValue = Astro.cookies.get(CART_COOKIE)?.value;
const held = new Set(await decodeCart(cartValue, serverEnv(Astro.locals, 'CART_SECRET')));

const MARQUEE_WORDS = ['ONE OF ONE', 'NOT REPRODUCED', 'FOUND ONCE', 'NEVER RESTOCKED', 'HELD ONCE', 'THEN GONE'];
const marquee = [...MARQUEE_WORDS, ...MARQUEE_WORDS];

// Shown once after self-service account deletion (/api/account/delete lands here).
const farewell = Astro.url.searchParams.get('farewell') === '1';
---

<Base>
  {farewell && (
    <div role="status" style="border-bottom:1px solid var(--gold); background:var(--bg-card); color:var(--ivory); text-align:center; padding:12px 18px; font-size:.92rem; letter-spacing:.02em;">
      Your account is closed — what you bought remains yours.
    </div>
  )}
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-brand">DOKU</div>
      <div class="hero-tagline">Found. Not made.</div>
      <h1 class="hero-headline" style="margin-top:36px;">Only one.<br /><em>So are you.</em></h1>
      <a href="/collection" class="hero-cta"><span>Explore the collection</span></a>
    </div>
    <div class="hero-scroll" aria-hidden="true">
      <div class="hero-scroll-line"></div>
      <svg width="11" height="7" viewBox="0 0 11 7" fill="none">
        <path d="M1 1L5.5 5.5L10 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
  </section>

  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {marquee.map((word) => (
        <>
          <span>{word}</span><span class="gold">·</span>
        </>
      ))}
    </div>
  </div>

  <div class="manifesto">
    <p>"We do not manufacture. We do not commission. We go looking — and when we find the one made in a way that will not repeat, we bring it back exactly as it was."</p>
  </div>

  {available.length > 0 && (
    <>
      <section class="section-head">
        <div class="eyebrow">Currently held</div>
        <h2 class="serif">Available now</h2>
        <p>Every piece below exists once — same as the people who keep them. Once it's gone, this page forgets it was ever here.</p>
      </section>
      <div class="carousel wrap" style="padding:0; margin-bottom:100px;">
        <div class="carousel-track">
          {available.map((p) => <ItemCard product={p} held={held.has(p.sku)} currency={currency} rates={rates} />)}
        </div>
      </div>
      <div style="text-align:center; padding:0 0 80px;">
        <a href="/collection" class="more">View the full collection →</a>
      </div>
    </>
  )}

  {comingSoon.length > 0 && (
    <>
      <section class="section-head">
        <div class="eyebrow">Still being found</div>
        <h2 class="serif">Coming soon</h2>
        <p>Directions we're chasing. Not yet found, not yet priced.</p>
      </section>
      <div class="grid wrap" style="padding:0; margin-bottom:100px;">
        {comingSoon.map((p) => <ItemCard product={p} currency={currency} rates={rates} />)}
      </div>
    </>
  )}

  {claimed.length > 0 && (
    <>
      <section class="section-head">
        <div class="eyebrow">No longer available</div>
        <h2 class="serif">The archive</h2>
        <p>Once held by DOKU. Now held by someone else — and not by anyone after them.</p>
      </section>
      <div class="archive-grid wrap" style="padding:0; margin-bottom:100px;">
        {claimed.slice(0, 4).map((p) => <ArchiveCard product={p} />)}
      </div>
    </>
  )}
</Base>
