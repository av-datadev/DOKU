---
import '../styles/tokens.css';
import '../styles/shell.css';
import '../styles/catalog.css';
import '../styles/item.css';
import '../styles/checkout.css';
import '../styles/bars.css';
import '../styles/hero.css';
import '../styles/archive.css';
import '../styles/provenance.css';
import '../styles/ambient.css';
import '../styles/reveal.css';
import '../styles/legal.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RegionBar from '../components/RegionBar.astro';
import ConsentBar from '../components/ConsentBar.astro';
import Ambient from '../components/Ambient.astro';
import Reveal from '../components/Reveal.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'DOKU — one-of-one objects',
  description = 'A marketplace for one-of-one objects. Each is genuinely unique, sold once, never restocked.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0E0C0A" />
    <script is:inline>
      // Mark JS-capable BEFORE first paint so scroll-reveal hidden states apply
      // without a flash (see reveal.css). No-JS visitors never get the hidden
      // states, so content stays visible for them.
      document.documentElement.classList.add('js');
    </script>
    <script is:inline>
      // GA4 stub — defined but never loaded/configured until the visitor
      // clicks Accept on the consent bar (see ConsentBar.astro). Decline, or
      // ignoring the bar, means no GA request ever fires.
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      const GA_ID = 'G-S1MKLYC4QS';
      function loadAnalytics() {
        if (window._gaLoaded) return;
        window._gaLoaded = true;
        const s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
        document.head.appendChild(s);
        gtag('js', new Date());
        gtag('config', GA_ID, { send_page_view: false });
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@300;400;500;600&family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Ambient />
    <Header />
    <main id="app">
      <slot />
    </main>
    <Footer />
    <RegionBar />
    <ConsentBar />
    <Reveal />
  </body>
</html>
