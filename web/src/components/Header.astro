---
import { CART_COOKIE, decodeCart } from '../lib/cart';
import { serverEnv } from '../lib/env';
import { CURRENCIES, SYMBOLS, currencyFromCookieValue, CURRENCY_COOKIE } from '../lib/currency';

// Active nav state is computed server-side from the real route — no more
// client-only #/hash matching.
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => path === href || path.startsWith(href + '/');

// Live cart count, read from the signed cookie (Hard rule 3: no localStorage).
// serverEnv reads CART_SECRET from the Cloudflare runtime in prod, .env in dev.
const cartValue = Astro.cookies.get(CART_COOKIE)?.value;
const cartCount = (await decodeCart(cartValue, serverEnv(Astro.locals, 'CART_SECRET'))).length;

// Currency choice lives in a plain (unsigned) cookie — it's display-only, never
// a trust boundary: the real charge is always computed server-side from catalog
// USD prices (razorpay-create-order), never from what the client claims. Reading
// it here means the very first paint is already in the visitor's currency.
const currency = currencyFromCookieValue(Astro.cookies.get(CURRENCY_COOKIE)?.value);

// Signed-in shoppers get an Account link; everyone else, a quiet way in. Resolved
// once per request in middleware (locals.user) — no extra work here.
const signedIn = !!Astro.locals.user;

const NAV = [
  { href: '/collection', label: 'The Collection' },
  { href: '/archive', label: 'The Archive' },
  { href: '/provenance', label: 'Provenance' },
  { href: '/inquire', label: 'Inquire' },
];
---

<header id="site-header">
  <a href="/" class="logo" aria-label="DOKU — home" data-cursor="Home">DOKU</a>
  <div class="header-right">
    <div class="currency-select-wrap">
      <button
        class="currency-btn"
        id="currency-btn"
        aria-haspopup="listbox"
        aria-expanded="false"
        title="Prices convert at indicative rates"
      >
        <span id="currency-label">{currency}</span>
        <svg width="9" height="6" viewBox="0 0 9 6" fill="none" stroke="currentColor" stroke-width="1.2">
          <polyline points="1,1 4.5,5 8,1" />
        </svg>
      </button>
      <div class="currency-dropdown" id="currency-dropdown" role="listbox">
        {CURRENCIES.map((code) => (
          <div
            class:list={['currency-option', { active: code === currency }]}
            data-cur={code}
            role="option"
            aria-selected={code === currency}
            tabindex="0"
          >
            <span>{code}</span><span class="cur-symbol">{SYMBOLS[code]}</span>
          </div>
        ))}
      </div>
    </div>

    <nav class="nav-links" id="nav-links">
      {NAV.map((n) => (
        <a href={n.href} class:list={[{ active: isActive(n.href) }]}>{n.label}</a>
      ))}
      <a href="/cart" class:list={['cart-link', { active: isActive('/cart') }]}>
        Cart <span class="cart-count" id="cart-count-desktop" hidden={cartCount === 0}>{cartCount}</span>
      </a>
      <a href={signedIn ? '/account' : '/login'} class:list={[{ active: isActive('/account') || isActive('/login') }]}>
        {signedIn ? 'Account' : 'Sign in'}
      </a>
    </nav>

    <button class="menu-btn" id="menu-btn" aria-label="Open menu"><span></span><span></span><span></span></button>
  </div>
</header>

<div id="mobile-menu-backdrop"></div>
<div id="mobile-menu">
  <button class="close-btn" id="menu-close">Close</button>
  {NAV.map((n) => <a href={n.href}>{n.label}</a>)}
  <a href="/cart">Cart {cartCount > 0 ? `(${cartCount})` : ''}</a>
  <a href={signedIn ? '/account' : '/login'}>{signedIn ? 'Account' : 'Sign in'}</a>
</div>

<script>
  import { applyCurrency } from '../lib/currency-client';

  // Progressive enhancement for the shell. The header renders and links work
  // without JS; this only adds the scroll-shrink, the mobile drawer, and the
  // currency dropdown (which reprices every [data-usd] element on the page
  // in place — see lib/currency-client.ts).
  const header = document.getElementById('site-header');
  const onScroll = () => header?.classList.toggle('scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const menu = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('mobile-menu-backdrop');
  const openMenu = () => { menu?.classList.add('open'); backdrop?.classList.add('open'); };
  const closeMenu = () => { menu?.classList.remove('open'); backdrop?.classList.remove('open'); };
  document.getElementById('menu-btn')?.addEventListener('click', openMenu);
  document.getElementById('menu-close')?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));

  const curBtn = document.getElementById('currency-btn');
  const curDrop = document.getElementById('currency-dropdown');
  const toggleCur = (open?: boolean) => {
    const next = open ?? !curDrop?.classList.contains('open');
    curDrop?.classList.toggle('open', next);
    curBtn?.classList.toggle('open', next);
    curBtn?.setAttribute('aria-expanded', String(next));
  };
  curBtn?.addEventListener('click', (e) => { e.stopPropagation(); toggleCur(); });

  const chooseCurrency = async (opt: HTMLElement) => {
    if (!opt.dataset.cur) return;
    await applyCurrency(opt.dataset.cur);
    toggleCur(false);
  };
  curDrop?.querySelectorAll<HTMLElement>('.currency-option').forEach((opt) => {
    opt.addEventListener('click', () => chooseCurrency(opt));
    opt.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); chooseCurrency(opt); }
    });
  });
  document.addEventListener('click', () => toggleCur(false));
</script>
