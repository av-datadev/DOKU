{
  // Scoped Worker config for the Astro app ONLY. Its presence stops the
  // Cloudflare adapter from climbing to the repo-root wrangler.jsonc (which
  // serves the current static single-file site). The two deploys stay separate
  // until the cutover. `nodejs_compat` is needed by @supabase/supabase-js.
  "name": "doku-web",
  // Domain + the existing "doku" Worker live under Pushpak1999gupta's
  // Cloudflare account, not the account this deploy is authenticated as by
  // default — pinned explicitly so `wrangler deploy` can't land in the wrong
  // account when the token has access to more than one.
  "account_id": "3e2f9dda8bd9688cf486b1cd9e5821e0",
  "compatibility_date": "2026-07-07",
  "compatibility_flags": ["nodejs_compat"],
  // Sentry error monitoring. A Sentry DSN is a write-only ingest key (safe to
  // expose, same class as a browser DSN), so it lives as a plain var, not a
  // secret — read via serverEnv() in web/src/lib/sentry.ts. NOTE: adding this
  // `vars` block makes wrangler.jsonc the source of truth for plaintext vars on
  // deploy; secrets (CART_SECRET, RAZORPAY_*, PHONE_AUTH_ENABLED if ever set as
  // a secret) are managed separately and are NOT affected. If PHONE_AUTH_ENABLED
  // is ever set as a plaintext var, add it here too so a deploy doesn't drop it.
  "vars": {
    "SENTRY_DSN": "https://c9e59ba11261521cfb64b18666157efb@o4511745144061952.ingest.de.sentry.io/4511745519779920"
  },
  "main": "./dist/_worker.js/index.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  // Product photography, once it exists (see CLAUDE.md "Known gaps" — no
  // real photos yet). Bucket created 2026-07-16; nothing reads/writes it yet
  // — the admin upload path and the image-serving route are still to build.
  "r2_buckets": [
    { "binding": "PRODUCT_IMAGES", "bucket_name": "doku-product-images" }
  ],
  // CUTOVER: custom_domain:true makes `wrangler deploy` claim discoverdoku.com
  // for this Worker directly — Cloudflare only allows one Worker per custom
  // domain, so this single deploy is also the moment traffic switches away
  // from the old "doku" Worker. Do not deploy this until ready to go live —
  // see project memory for the required order of operations (this must
  // happen BEFORE revoking anon's place_order() grant, not after).
  // www is a second custom_domain so visitors typing (or linking) the www host
  // don't hit an NXDOMAIN — it had no DNS record at all. custom_domain makes
  // Cloudflare provision the www hostname + DNS for this same Worker, so www
  // serves the site directly (apex stays canonical; no redirect layer here).
  "routes": [
    { "pattern": "discoverdoku.com", "custom_domain": true },
    { "pattern": "www.discoverdoku.com", "custom_domain": true }
  ]
}
